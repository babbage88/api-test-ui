    "request_type": "ValkeyInstallRequest",
    "response_type": "ValkeyInstallResult",
    "body": {
      "ssh": {
        "host": "cache.example.internal",
        "user": "ubuntu",
        "private_key_base64": "base64-encoded-private-key",
        "use_agent": true,
        "port": 22
      },
      "username": "app",
      "password": "secret",
      "bind": "0.0.0.0",
      "port": 6379
    },
    "response_example": {
      "host": "cache.example.internal",
      "port": 6379,
      "username": "app",
      "uri": "redis://app:secret@cache.example.internal:6379"
    }
  }
